# Google Earth Engine
# 1. Register at https://code.earthengine.google.com (non-commercial is free).
# 2. Note the project ID from your Cloud Project.
GEE_PROJECT_ID=

# Path to a Google Cloud service account JSON key with Earth Engine and
# Cloud Storage permissions. Leave blank to fall back to interactive
# `earthengine authenticate` and `gcloud auth application-default login`.
GOOGLE_APPLICATION_CREDENTIALS=

# Google Cloud Storage bucket. Must be in the same Cloud project as the GEE
# project above. The bucket name does not need a "gs://" prefix here.
GCS_BUCKET=

# GCS prefix under which all gee_s1s2_translator artefacts will be written.
# Final layout: gs://<GCS_BUCKET>/<GCS_PREFIX>/operational_v1/{patches,manifest.csv}
GCS_PREFIX=gee_s1s2_translator

# Logging level. Set to DEBUG for verbose GEE export progress.
GEE_S1S2_LOG_LEVEL=INFO
